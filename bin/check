#!/bin/sh

set -e

fail() {
    printf '%s\n' "$1" >&2  ## Send message to stderr. Exclude >&2 if you don't want it that way.
    exit "${2-1}"  ## Return a code specified by $2 or 1 by default.
}

diff() {
    git diff --no-ext-diff --quiet
}

diff || fail "uncommitted changes"

# Rust code checks
cargo fmt && diff || fail "unformatted rust code"
cargo check --all-targets --workspace || fail \
    && cargo check --all-targets --features parking_lot --workspace || fail
cargo clippy --all-targets --workspace || fail \
    && cargo clippy --all-targets --features parking_lot --workspace || fail
cargo test --all-targets --workspace || fail \
    && cargo test -p guide --features hot

# Build guide book
mdbook build guide/ || fail "unable to build guide book"

# Check for semver breaking changes: if this fails you must update the crate version or fix the code
cargo semver-checks check-release --default-features

echo "OK"
